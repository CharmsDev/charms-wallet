# Charms Wallet Extension - Environment Variables
# Copy this file to .env and fill in your values
# The .env file is gitignored and will be injected at build time

# Bitcoin Network (mainnet | testnet4)
VITE_BITCOIN_NETWORK=testnet4

# QuickNode Bitcoin API (for UTXO queries, tx broadcast)
VITE_QUICKNODE_TESTNET_URL=https://your-testnet4-endpoint.quiknode.pro/xxx/
VITE_QUICKNODE_TESTNET_API_KEY=xxx
VITE_QUICKNODE_MAINNET_URL=https://your-mainnet-endpoint.quiknode.pro/xxx/
VITE_QUICKNODE_MAINNET_API_KEY=xxx

# Charms Explorer API (for charms/tokens data)
VITE_CHARMS_API_URL=https://api-t4.charms.dev

# Prover API (for spell proving)
VITE_PROVER_TESTNET4_URL=https://prove-t4.charms.dev
VITE_PROVER_MAINNET_URL=https://v7.charms.dev/spells/prove

# Fallback: Mempool.space API (public, no key needed)
# Used when QuickNode is not configured
VITE_MEMPOOL_API_URL=https://mempool.space/testnet4/api
